{
	"geode": "5.3.0",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "ziegenhainy.basenpercent",
	"name": "Base N Percentage",
	"version": "v1.0.0",
	"developer": "Ziegenhainy",
	"description": "Turns the percentage into any Base n",
	"dependencies": {
		"geode.node-ids": ">=v1.20.0"
	},
	"tags": [
		"enhancement",
		"offline",
		"customization",
		"joke"
	],
	"settings": {
		"base-n": {
			"type": "int",
			"name": "Base N",
			"default": 16,
			"min": 2,
			"max": 64,
			"control": {
				"arrows": true,
				"arrow-step": 1,
